{
  "private": true,
  "type": "module",
  "description": "基于 JSON Schema 配置的动态表单组件",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@plugins/injectStyleCss": "workspace:*",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^20.3.9",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass": "^1.70.0",
    "terser": "^5.46.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^7.18.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "dev": "vite",
    "dev:vant": "pnpm --filter vant dev",
    "build": "pnpm -r run build",
    "build:analyze": "pnpm -r --filter @schemx/core --filter @schemx/vue --filter @schemx/vant run build:analyze",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "pnpm -r run test",
    "test:watch": "vitest",
    "lint": "pnpm -r run lint",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx,vue,js,jsx}\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{vue,ts,tsx,js,jsx,json,css,scss}\"",
    "release:check": "bash scripts/release.sh check",
    "release:pack": "bash scripts/release.sh pack",
    "release:publish": "bash scripts/release.sh publish",
    "release:publish:dev": "bash scripts/release.sh publish-dev",
    "release:publish:alpha": "bash scripts/release.sh publish-alpha",
    "release:publish:beta": "bash scripts/release.sh publish-beta",
    "release:publish:rc": "bash scripts/release.sh publish-rc",
    "release:publish:next": "bash scripts/release.sh publish-next",
    "release:version:patch": "bash scripts/release.sh version patch",
    "release:version:minor": "bash scripts/release.sh version minor",
    "release:version:major": "bash scripts/release.sh version major",
    "release:test": "bash scripts/release.test.sh && bash scripts/bump-version.test.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/schemx.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "form",
    "schemx",
    "dynamic-form",
    "vant",
    "json-schema"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-org/schemx/issues"
  },
  "homepage": "https://github.com/your-org/schemx#readme"
}

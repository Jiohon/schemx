{
  "private": true,
  "type": "module",
  "description": "基于 JSON Schema 配置的 Vue 3 动态表单组件",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-plugin-vue": "^9.33.0",
    "fast-check": "^4.5.3",
    "happy-dom": "^20.3.9",
    "prettier": "^3.8.1",
    "sass": "^1.70.0",
    "terser": "^5.46.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^7.18.0",
    "vant": "^4.9.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^4.0.18",
    "vue": "^3.4.0",
    "zod": "^4.3.6"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm -r run build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "pnpm -r run test",
    "test:watch": "vitest",
    "lint": "pnpm -r run lint",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx,vue,js,jsx}\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{vue,ts,tsx,js,jsx,json,css,scss}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vue-schema-form.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "form",
    "schema-form",
    "dynamic-form",
    "vant",
    "json-schema"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-org/vue-schema-form/issues"
  },
  "homepage": "https://github.com/your-org/vue-schema-form#readme"
}

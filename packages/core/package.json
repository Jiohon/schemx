{
  "type": "module",
  "name": "@schemx/core",
  "version": "0.1.23",
  "description": "框架无关的表单引擎核心（Framework-agnostic form engine core）",
  "keywords": [
    "schemx",
    "form",
    "form-engine",
    "dynamic-form",
    "json-schema",
    "validation",
    "framework-agnostic"
  ],
  "homepage": "https://github.com/Jiohon/schemx/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Jiohon/schemx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jiohon/schemx.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@preact/signals-core": "^1.14.0",
    "csstype": "^3.2.3",
    "es-toolkit": "catalog:"
  },
  "scripts": {
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx,vue,js,jsx}\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/*.spec.*\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "fast-check": "^4.6.0",
    "vue": "catalog:"
  }
}

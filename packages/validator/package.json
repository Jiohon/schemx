{
  "type": "module",
  "name": "@schemx/validator",
  "version": "0.1.0",
  "description": "Schemx 的第三方校验器适配包",
  "keywords": [
    "schemx",
    "form",
    "validation",
    "zod",
    "async-validator"
  ],
  "homepage": "https://github.com/Jiohon/schemx/tree/main/packages/validator#readme",
  "bugs": {
    "url": "https://github.com/Jiohon/schemx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jiohon/schemx.git",
    "directory": "packages/validator"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./zod": {
      "import": {
        "types": "./dist/zod.d.ts",
        "default": "./dist/zod.mjs"
      },
      "require": {
        "types": "./dist/zod.d.ts",
        "default": "./dist/zod.cjs"
      }
    },
    "./async-validator": {
      "import": {
        "types": "./dist/async-validator.d.ts",
        "default": "./dist/async-validator.mjs"
      },
      "require": {
        "types": "./dist/async-validator.d.ts",
        "default": "./dist/async-validator.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.mjs"
      },
      "require": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@schemx/core": "workspace:*",
    "async-validator": "^4.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "async-validator": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "scripts": {
    "build": "pnpm run type-check && vite build",
    "build:analyze": "vite build",
    "test": "vitest run && pnpm run test:exports",
    "test:exports": "pnpm run build && node scripts/exports-smoke.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm run lint && pnpm run format:check && pnpm run type-check",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@schemx/core": "workspace:*",
    "async-validator": "^4.2.5",
    "zod": "^4.4.3"
  }
}

{
  "type": "module",
  "name": "@schemx/vue",
  "version": "0.1.11",
  "description": "基于 JSON Schema 配置的 Vue 3 动态表单引擎（UI 无关核心）",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@schemx/core": "workspace:*",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.44.0"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx,vue,js,jsx}\"",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT"
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@schemx/core": ["../../packages/core/src/index.ts"],
      "@schemx/core/*": ["../../packages/core/src/*"],
      "@schemx/vue": ["../../packages/vue/src/index.ts"],
      "@schemx/vue/*": ["../../packages/vue/src/*"],
      "@schemx/vant": ["../../packages/vant/src/index.ts"],
      "@schemx/vant/*": ["../../packages/vant/src/*"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@schemx/core": ["../../packages/core/src/index.ts"],
      "@schemx/core/*": ["../../packages/core/src/*"],
      "@schemx/vue": ["../../packages/vue/src/index.ts"],
      "@schemx/vue/*": ["../../packages/vue/src/*"]
    },
    "rootDir": "./src",
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist",
    "outDir": "./dist"
  },
  "references": [{ "path": "../core" }, { "path": "../vue" }],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}

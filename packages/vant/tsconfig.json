{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@jonhn/schema-form-core": ["../../packages/core/src/index.ts"],
      "@jonhn/schema-form-core/*": ["../../packages/core/src/*"]
    },
    "declarationDir": "./dist",
    "outDir": "./dist",
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}

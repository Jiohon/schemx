{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@schemx/core": ["../../packages/core/src/index.ts"],
      "@schemx/core/*": ["../../packages/core/src/*"],
      "@schemx/vue": ["../../packages/vue/src/index.ts"],
      "@schemx/vue/*": ["../../packages/vue/src/*"]
    },
    "noEmit": false,
    "declaration": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}

{
  "type": "module",
  "name": "@schemx/vant",
  "version": "0.1.10",
  "description": "基于 Vant 组件库的 schemx 渲染器适配包",
  "keywords": [
    "schemx",
    "vant",
    "vue",
    "vue3",
    "form",
    "dynamic-form",
    "json-schema"
  ],
  "homepage": "https://github.com/Jiohon/schemx/tree/main/packages/vant#readme",
  "bugs": {
    "url": "https://github.com/Jiohon/schemx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jiohon/schemx.git",
    "directory": "packages/vant"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/defaultRenderers.*",
    "**/index.ts"
  ],
  "peerDependencies": {
    "vant": "^4.0.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@schemx/core": "workspace:*",
    "@schemx/vue": "workspace:*",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "es-toolkit": "catalog:"
  },
  "scripts": {
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx,vue,js,jsx}\"",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "vant": "^4.9.0",
    "vue": "catalog:"
  }
}

{
  "name": "@schemx/vite-plugin-realpath-fallback",
  "version": "0.1.0",
  "description": "Retry unresolved Vite package imports from the importer's real filesystem path.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "pack:local": "bash ../../scripts/plugins/pack-vite-plugin.sh vite-plugin-realpath-fallback"
  },
  "peerDependencies": {
    "vite": ">=4.0.0 <9.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.15.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
